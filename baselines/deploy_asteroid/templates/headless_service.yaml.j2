---
apiVersion: v1
kind: Service
metadata:
  name: asteroid-master
  namespace: {{ namespace | default('default') }}
  labels:
    app: baselines-asteroid
    component: master-service
spec:
  clusterIP: None
  # Publish endpoints even when pods are not Ready yet.
  # Required for torch.distributed init_process_group:
  # all ranks must reach the master during startup,
  # before any pod passes a readiness check.
  publishNotReadyAddresses: true
  selector:
    app: baselines-asteroid
    rank: "0"
  ports:
    - name: torch-dist
      port: {{ master_port | default(29500) }}
      targetPort: {{ master_port | default(29500) }}
      protocol: TCP
