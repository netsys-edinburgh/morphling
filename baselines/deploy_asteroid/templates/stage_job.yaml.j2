---
# Kubernetes Job for baselines worker - Rank {{ rank }}
# =====================================================
# Stage: {{ stage }}
# Node: {{ node_hostname }}
#
# Generated by: baselines/deploy_asteroid/generate_manifests.py
apiVersion: batch/v1
kind: Job
metadata:
  name: asteroid-rank-{{ rank }}
  namespace: {{ namespace | default('default') }}
  labels:
    app: asteroid
    component: worker
    stage: "{{ stage }}"
    rank: "{{ rank }}"
spec:
  # Retry failed pods up to 3 times
  backoffLimit: 3
  # Clean up completed jobs after 1 hour
  ttlSecondsAfterFinished: 3600
  # Only run one pod (no parallelism within job)
  parallelism: 1
  completions: 1

  template:
    metadata:
      labels:
        app: asteroid
        component: worker
        stage: "{{ stage }}"
        rank: "{{ rank }}"
      annotations:
        # Prometheus metrics scraping (if configured)
        prometheus.io/scrape: "false"
    spec:
      restartPolicy: OnFailure

      # =========================================
      # Node selection - pin to specific hardware
      # =========================================
      nodeSelector:
        kubernetes.io/hostname: {{ node_hostname }}

      # Allow scheduling on GPU-tainted nodes
      tolerations:
        - key: "nvidia.com/gpu"
          operator: "Exists"
          effect: "NoSchedule"
        - key: "node-role.kubernetes.io/edge"
          operator: "Exists"
          effect: "NoSchedule"

      # =========================================
      # Init container - wait for master service
      # =========================================
      {% if rank != 0 %}
      initContainers:
        - name: wait-for-master
          image: busybox:1.36
          command:
            - sh
            - -c
            - |
              echo "Waiting for asteroid-master service..."
              until nslookup asteroid-master.{{ namespace | default('default') }}.svc.cluster.local; do
                echo "Master not ready, waiting..."
                sleep 2
              done
              echo "Master service is ready!"
          resources:
            requests:
              cpu: "10m"
              memory: "16Mi"
            limits:
              cpu: "100m"
              memory: "32Mi"
      {% endif %}

      # =========================================
      # Main container
      # =========================================
      containers:
        - name: baselines-worker
          image: {{ image | default('baselines:latest') }}
          imagePullPolicy: {{ image_pull_policy | default('IfNotPresent') }}

          # Resource requests and limits from profiled hardware
          resources:
            requests:
              memory: "{{ memory_request_mb | default(memory_mb) }}Mi"
              cpu: "{{ cpu_request | default('1000m') }}"
              nvidia.com/gpu: "1"
            limits:
              memory: "{{ memory_limit_mb | default((memory_mb * 1.5) | int) }}Mi"
              cpu: "{{ cpu_limit | default('8000m') }}"
              nvidia.com/gpu: "1"

          # =========================================
          # Environment variables for torch.distributed
          # =========================================
          env:
            # PyTorch distributed configuration
            - name: RANK
              value: "{{ rank }}"
            - name: WORLD_SIZE
              value: "{{ world_size }}"
            - name: LOCAL_RANK
              value: "0"
            - name: MASTER_ADDR
              value: "asteroid-master.{{ namespace | default('default') }}.svc.cluster.local"
            - name: MASTER_PORT
              value: "{{ master_port | default(29500) }}"

            # NCCL configuration
            - name: NCCL_SOCKET_IFNAME
              value: "eth0"
            - name: NCCL_DEBUG
              value: "{{ nccl_debug | default('WARN') }}"
            - name: NCCL_IB_DISABLE
              value: "{{ nccl_ib_disable | default('1') }}"
            - name: NCCL_P2P_DISABLE
              value: "{{ nccl_p2p_disable | default('1') }}"
            - name: NCCL_SHM_DISABLE
              value: "{{ nccl_shm_disable | default('0') }}"

            # CUDA configuration
            - name: CUDA_VISIBLE_DEVICES
              value: "{{ gpu_id }}"
            - name: CUDA_LAUNCH_BLOCKING
              value: "0"

            # Baselines plan configuration
            - name: HPP_PLAN_PATH
              value: "/config/hpp_plan.json"
            - name: STAGE_IDX
              value: "{{ stage }}"
            - name: MICRO_BATCH_SIZE
              value: "{{ micro_batch_size | default(4) }}"

            # HuggingFace cache
            - name: HF_HOME
              value: "/cache/huggingface"
            - name: TRANSFORMERS_CACHE
              value: "/cache/huggingface/transformers"

            # Python configuration
            - name: PYTHONUNBUFFERED
              value: "1"
            - name: TORCH_NCCL_BLOCKING_WAIT
              value: "1"
            # TensorBoard log directory (persistent on host)
            - name: TENSORBOARD_LOG_DIR
              value: "/tensorboard"

          # =========================================
          # Volume mounts
          # =========================================
          volumeMounts:
            # HPP plan from ConfigMap
            - name: config-volume
              mountPath: /config
              readOnly: true
            # Shared memory for NCCL
            - name: shm
              mountPath: /dev/shm
            # Cache for HuggingFace models/datasets
            - name: cache-volume
              mountPath: /cache
            # TensorBoard logs (persistent on host)
            - name: tensorboard-logs
              mountPath: /tensorboard

          # =========================================
          # Startup/liveness probes (optional)
          # =========================================
          # Note: Disabled by default as training jobs
          # may have long initialization periods
          # startupProbe:
          #   exec:
          #     command: ["python", "-c", "import torch"]
          #   initialDelaySeconds: 30
          #   periodSeconds: 10
          #   failureThreshold: 30

          # Working directory
          workingDir: /app

      # =========================================
      # Volumes
      # =========================================
      volumes:
        # ConfigMap with hpp_plan.json
        - name: config-volume
          configMap:
            name: asteroid-config

        # Shared memory - required for NCCL/PyTorch IPC
        - name: shm
          emptyDir:
            medium: Memory
            sizeLimit: "{{ shm_size | default('4Gi') }}"

        # Cache volume (emptyDir or PVC)
        - name: cache-volume
          {% if use_cache_pvc | default(false) %}
          persistentVolumeClaim:
            claimName: baselines-cache-{{ rank }}
          {% else %}
          emptyDir:
            sizeLimit: "{{ cache_size | default('10Gi') }}"
          {% endif %}
        # TensorBoard logs - hostPath persists across pod restarts
        - name: tensorboard-logs
          hostPath:
            path: /var/lib/baselines/tensorboard
            type: DirectoryOrCreate

      # DNS configuration for headless service resolution
      dnsPolicy: ClusterFirst
