# Asteroid Cluster Secrets Template
# =================================
#
# To use this file:
# 1. Create your vault password file:
#    echo "your-secure-password" > ~/.asteroid_vault_pass
#    chmod 600 ~/.asteroid_vault_pass
#
# 2. Create encrypted secrets.yml:
#    cd deploy
#    ansible-vault create secrets.yml
#
#    Then paste and edit the following content:
#
# ---
# # SSH credentials for edge nodes
# ansible_ssh_pass: "your-ssh-password"
# ansible_become_pass: "your-sudo-password"
#
# Alternatively, copy this file and encrypt:
#    cp secrets.yml.template secrets.yml
#    # Edit secrets.yml with your actual passwords
#    ansible-vault encrypt secrets.yml

---
# SSH credentials for edge nodes
ansible_ssh_pass: "CHANGE_ME"
ansible_become_pass: "CHANGE_ME"
